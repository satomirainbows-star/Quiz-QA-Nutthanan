{
  "name": "quiz-qa",
  "version": "1.0.0",
  "scripts": {
    "test:ui": "wdio run wdio.conf.js --spec 'features/ui/**/*.feature'",
    "test:ui:headed": "wdio run wdio.conf.js --spec 'features/ui/**/*.feature' --headed",
    "test:api": "wdio run wdio.conf.js --spec 'features/api/**/*.feature'",
    "test": "wdio run wdio.conf.js --spec 'features/**/*.feature'",
    "report": "node generate-report.js"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.0",
    "@wdio/cli": "^9.27.1",
    "@wdio/cucumber-framework": "^9.27.1",
    "@wdio/globals": "^9.27.1",
    "@wdio/json-reporter": "^9.20.0",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/spec-reporter": "^8.27.0",
    "chromedriver": "^147.0.0",
    "cucumber-html-reporter": "^6.0.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "wdio-cucumber-json-reporter": "^0.0.4",
    "wdio-cucumberjs-json-reporter": "^6.0.1",
    "webdriverio": "^9.27.1"
  }
}
